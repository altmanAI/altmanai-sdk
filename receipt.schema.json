{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.altmanai.tech/receipt.schema.json",
  "title": "Receipt",
  "type": "object",
  "required": [
    "id",
    "type",
    "actor",
    "summary",
    "source",
    "timestamp",
    "hash"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "actor": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "hash": {
      "type": "string"
    },
    "metadata": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
