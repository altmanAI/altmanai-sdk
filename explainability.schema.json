{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.altmanai.tech/explainability.schema.json",
  "title": "ExplainabilityRecord",
  "type": "object",
  "required": [
    "decision",
    "reason",
    "timestamp"
  ],
  "properties": {
    "decision": {
      "type": "string"
    },
    "reason": {
      "type": "string"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "actor": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "additionalProperties": false
}
